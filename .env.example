# Доступ к админке (защита /admin)
ADMIN_TOKEN=changeme

# База данных.
# Примеры:
# - Render/Neon:
#   DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname?ssl=require
# - Локально (Postgres):
#   DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app
# По умолчанию в тестах используется SQLite in-memory.
DATABASE_URL=

# Очередь RabbitMQ (CloudAMQP или локально)
RABBITMQ_URL=amqp://guest:guest@localhost/
RMQ_EXCHANGE=bridge
RMQ_TASK_QUEUE=bridge.tasks
RMQ_RETRY_QUEUE=bridge.tasks.retry
RMQ_DLQ_QUEUE=bridge.tasks.dlq
RMQ_RETRY_TTL_MS=5000
RMQ_ENABLE_CONSUMER=true
RMQ_CONSUMERS=1

# -------- AmoCRM: базовые настройки OAuth --------
AMO_BASE_URL=https://YOUR.amocrm.ru
AMO_CLIENT_ID=
AMO_CLIENT_SECRET=
AMO_REDIRECT_URI=https://your-domain.example/oauth/amo/callback

# Воронки и этапы
AMO_PIPELINE_ID_MASTER=
AMO_STAGE_ID_MASTER_NEW=
AMO_STAGE_ID_MASTER_SURVEY=
AMO_PIPELINE_ID_OPERATOR=
AMO_STAGE_ID_OPERATOR_NEW=
AMO_STAGE_ID_OPERATOR_SURVEY=

# Теги и ключевые слова маршрутизации
AMO_TAG_WENT_TO_BOT=Перешел в бота
AMO_TAG_SURVEY_DONE=Опрос пройден
ROUTING_KEYWORD_MASTER=мастер
ROUTING_KEYWORD_OPERATOR=оператор



# -------- AmoChats (amojo) --------
AMOCHATS_ENABLED=true
AMO_CHATS_BASE=https://amojo.amocrm.ru
AMO_CHATS_SCOPE_ID=
AMO_CHATS_SECRET=
AMO_CHATS_CHANNEL_ID=
AMO_CHATS_ACCOUNT_ID=
AMO_CHATS_SENDER_USER_AMOJO_ID=
AMO_CHATS_SENDER_NAME=tg-bridge
AMO_CHATS_AUTOCONNECT=true
AMOCHATS_INCOMING_SECRET=
# Dev only: bypass AmoChats incoming signature check (DON'T enable in prod)
AMOCHATS_SKIP_SIGNATURE=false

# -------- Telegram --------
TELEGRAM_MASTER_BOT_TOKEN=
TELEGRAM_MASTER_BOT_USERNAME=
TELEGRAM_OPERATOR_BOT_TOKEN=
TELEGRAM_OPERATOR_BOT_USERNAME=
TELEGRAM_WEBHOOK_BASE=https://your-domain.example
TELEGRAM_WEBHOOK_MODE=true
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_TIMEOUT=10
TELEGRAM_WEBHOOK_RETRIES=3
TELEGRAM_WEBHOOK_RETRY_DELAY=1.0

# -------- HeadHunter (HH) --------
HH_CLIENT_ID=
HH_CLIENT_SECRET=
HH_REDIRECT_URI=https://your-domain.example/oauth/hh/callback
HH_API_BASE=https://api.hh.ru
HH_SET_STATE_PATH=/negotiations/{response_id}/status
HH_TOKEN_URL=https://api.hh.ru/oauth/token
HH_USER_AGENT=hr-bridge/1.0 (you@example.com)
HH_SYNC_ENABLED=false
HH_AUTOFILL_INTERVAL_HOURS=0
# Управление вебхуками: поддерживаемые события -> negotiation.created, negotiation.status_changed
HH_WEBHOOK_URL=https://your-domain.example/webhooks/hh
HH_WEBHOOK_EVENTS=negotiation.created,negotiation.status_changed

# -------- Avito --------
AVITO_CLIENT_ID=
AVITO_CLIENT_SECRET=
AVITO_REDIRECT_URI=https://your-domain.example/oauth/avito/callback
AVITO_AUTHORIZE_URL=https://avito.ru/oauth
AVITO_TOKEN_URL=https://api.avito.ru/token
AVITO_SCOPE=messenger:read messenger:write
AVITO_API_BASE=https://api.avito.ru
AVITO_SEND_MESSAGE_PATH=/messenger/v1/accounts/me/chats/{negotiation_id}/messages
AVITO_MARK_READ_PATH=/messenger/v1/accounts/me/chats/{negotiation_id}/read
AVITO_SYNC_ENABLED=false
AVITO_MARK_READ_ON_STAGE_CHANGE=true
AVITO_WEBHOOK_URL=https://your-domain.example/webhooks/avito
AVITO_MESSENGER_EVENTS=message,delivery,read
AVITO_WEBHOOK_SECRET=
AVITO_SIGNATURE_HEADER=X-Avito-Signature

